apiVersion: bootstrap.cluster.x-k8s.io/v1beta1
kind: RKE2ConfigTemplate
metadata:
  labels:
    cluster.x-k8s.io/cluster-name: <%= cluster[:uuid] %>
  name: <%= group[:uuid] %>
spec:
  template:
    spec:
      agentConfig:
        kubelet:
          extraArgs:
          - --cloud-provider=external
      preRKE2Commands:
      - (RETRY=60; while ! nslookup get.rke2.io; do ((--RETRY)) || break; sleep 5;
        done)
---
apiVersion: cluster.x-k8s.io/v1beta1
kind: MachineDeployment
metadata:
  labels:
    cluster.x-k8s.io/cluster-name: <%= cluster[:uuid] %>
  name: <%= group[:uuid] %>
spec:
  clusterName: <%= cluster[:uuid] %>
  replicas: <%= group[:user_inputs_values][:count] %>
  selector:
    matchLabels: {}
  template:
    spec:
      bootstrap:
        configRef:
          apiVersion: bootstrap.cluster.x-k8s.io/v1beta1
          kind: RKE2ConfigTemplate
          name: <%= group[:uuid] %>
      clusterName: <%= cluster[:uuid] %>
      infrastructureRef:
        apiVersion: infrastructure.cluster.x-k8s.io/v1beta1
        kind: ONEMachineTemplate
        name: <%= group[:uuid] %>
      version: <%= cluster[:kubernetes_version] %>+rke2r1
---
apiVersion: infrastructure.cluster.x-k8s.io/v1beta1
kind: ONEMachineTemplate
metadata:
  labels:
    cluster.x-k8s.io/cluster-name: <%= cluster[:uuid] %>
  name: <%= group[:uuid] %>
spec:
  template:
    spec:
      templateName: <%= group[:group_template_name] %>
---
apiVersion: cluster.x-k8s.io/v1beta1
kind: MachineHealthCheck
metadata:
  name: "<%= group[:uuid] %>"
spec:
  clusterName: <%= cluster[:uuid] %>
  selector:
    matchLabels:
      cluster.x-k8s.io/deployment-name: "<%= group[:uuid] %>"
  nodeStartupTimeout: 15m
  maxUnhealthy: 100%
  unhealthyConditions:
  - type: Ready
    status: "False"
    timeout: 5m
  - type: Ready
    status: "Unknown"
    timeout: 5m
